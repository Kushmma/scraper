# ── NepCompare Environment Variables ──

# Flask
SECRET_KEY=nepcompare-dev-secret-key-change-me
FLASK_DEBUG=1
HOST=0.0.0.0
PORT=5000

# Database
DATABASE_URL=sqlite:///nepcompare.db

# Scraper
SCRAPER_HEADLESS=1
SCRAPER_MIN_DELAY=2.0
SCRAPER_MAX_DELAY=5.0
SCRAPER_MAX_RETRIES=3
SCRAPER_PAGE_LOAD_TIMEOUT=30
SCRAPER_MAX_PRODUCTS_PER_SEARCH=50

# Scheduler
SCHEDULER_ENABLED=0
SCHEDULER_INTERVAL_HOURS=6

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=momo

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
